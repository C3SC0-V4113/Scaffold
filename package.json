{
  "name": "purrfold",
  "version": "0.1.0",
  "description": "Scaffold a production-ready frontend app with shadcn, strict quality tooling, agent docs, Claude hooks, and optional tests. Starts with Next.js. 🐱",
  "type": "module",
  "bin": {
    "purrfold": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "scaffold",
    "scaffolding",
    "cli",
    "create-next-app",
    "nextjs",
    "shadcn",
    "eslint",
    "prettier",
    "react-doctor",
    "quality",
    "react",
    "frontend"
  ],
  "author": "Valle-Aracari <jose.valle@aracaristudios.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/C3SC0-V4113/Scaffold.git"
  },
  "homepage": "https://github.com/C3SC0-V4113/Scaffold#readme",
  "bugs": {
    "url": "https://github.com/C3SC0-V4113/Scaffold/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm run test && npm run build",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "commander": "^14.0.2",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
